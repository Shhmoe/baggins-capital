# Baggins OpenSource Company — Environment Variables
# Copy this to .env and fill in your keys
# cp .env.example .env

# ===================
# REQUIRED
# ===================

# Anthropic API Key (for AI reasoning in heartbeat and analysis)
# Get one at: https://console.anthropic.com/
API_KEY=

# Bankr Trading API (for Polymarket execution)
# Get one at: https://bankr.bot/
BANKR_API_KEY=

# ===================
# WEATHER APIS (optional — more sources = better forecasts)
# ===================
# Open-Meteo and NOAA work without keys.
# Adding more sources improves forecast consensus accuracy.

# https://www.weatherapi.com/ (free tier)
WEATHERAPI_KEY=

# https://openweathermap.org/api (free tier)
OPENWEATHERMAP_KEY=

# https://www.visualcrossing.com/ (free tier)
VISUALCROSSING_KEY=

# https://www.weatherbit.io/ (free tier)
WEATHERBIT_KEY=

# https://pirateweather.net/ (free tier)
PIRATEWEATHER_KEY=

# ===================
# SPORTS (optional)
# ===================
# https://the-odds-api.com/ (free tier — 500 requests/month)
ODDS_API_KEY=

# ===================
# NOTIFICATIONS (optional)
# ===================
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===================
# ADVANCED (optional)
# ===================
# Shared directory for inter-service communication
# SHARED_DIR=~/shared
